    {
      "name": "4. Papers and Reports",
      "item": [
        {
          "name": "GET /api/papers/search",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/papers/search?query={{query}}&sortBy=relevance&page=1&pageSize=5&type=conference",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "papers",
                "search"
              ],
              "query": [
                {
                  "key": "query",
                  "value": "{{query}}"
                },
                {
                  "key": "sortBy",
                  "value": "relevance"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "5"
                },
                {
                  "key": "type",
                  "value": "conference"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.results && json.results.length > 0) {",
                  "  pm.environment.set('paperId', json.results[0].id);",
                  "}",
                  "pm.test('has required keys', function () {",
                  "  pm.expect(json).to.have.property('results');",
                  "  pm.expect(json).to.have.property('facets');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /api/reports/generate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"

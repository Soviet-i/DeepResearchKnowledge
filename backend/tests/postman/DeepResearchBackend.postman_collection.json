            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"{{query}}\",\n  \"reportType\": \"summary\",\n  \"papers\": [\n    {\n      \"id\": \"demo-paper\",\n      \"title\": \"Demo Paper\",\n      \"authors\": [\"Alice\", \"Bob\"],\n      \"publicationYear\": 2025,\n      \"source\": \"Test Source\",\n      \"abstract\": \"Demo abstract\",\n      \"relevanceScore\": 90,\n      \"type\": \"journal\"\n    }\n  ]\n}"
            },
